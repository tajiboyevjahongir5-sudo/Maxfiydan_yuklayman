# ============================================================
#  TELEGRAM MEDIA BOT — Environment Variables (Namuna fayl)
#  Bu faylni nusxalab .env deb saqlang va qiymatlarni to'ldiring
# ============================================================

# --- Aiogram Bot sozlamalari ---
# @BotFather dan olinadigan bot token
BOT_TOKEN=7937590583:AAFggO1Ps4hYyOSURv-91fVZh8_kSCaBGSM

# --- Pyrogram Userbot sozlamalari ---
# https://my.telegram.org/apps dan olinadigan API ID va HASH
API_ID=37685416
API_HASH=7e8a3a8ed60dd65871bбa24556ac0e68

# --- Pyrogram Session String ---
# Session string olish uchun: python generate_session.py
# Keyin u yerda chiqadigan stringni quyiga joylashtiring
PYROGRAM_SESSION_STRING=BQxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Ixtiyoriy sozlamalar ---
# Faqat ruxsat berilgan foydalanuvchilar ID'lari (vergul bilan ajrating)
# Bo'sh qoldirsangiz, hamma foydalana oladi
ALLOWED_USERS=

# Vaqtinchalik fayllar saqlanadigan papka (default: ./downloads)
DOWNLOAD_DIR=./downloads

# Fayl yuklashda maksimal hajm (MB), 0 = cheklovsiz
MAX_FILE_SIZE_MB=2000
